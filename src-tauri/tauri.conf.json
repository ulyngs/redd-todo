{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ReDD To-Do",
  "version": "2.7.5",
  "identifier": "com.redd.do",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "macOSPrivateApi": false,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ReDD To-Do",
        "width": 540,
        "height": 600,
        "minWidth": 460,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "zoomHotkeysEnabled": false,
        "transparent": false,
        "alwaysOnTop": false,
        "visible": true,
        "backgroundColor": [
          255,
          255,
          255,
          255
        ]
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "copyright": "Copyright © 2026 Reduce Digital Distraction Ltd",
    "shortDescription": "ReDD To-Do: Goals in Sight",
    "longDescription": "ReDD To-Do: Goals in Sight helps you stay focused with a calm, distraction-free todo app, focus mode, and time tracking. Your data lives on your device — nothing is collected.",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.15",
      "providerShortName": null,
      "signingIdentity": "Developer ID Application: Reduce Digital Distraction Ltd (JD647S9RT6)"
    },
    "resources": [
      "reminders-connector"
    ],
    "externalBin": []
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://redd-todo.netlify.app/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": ""
    },
    "deep-link": {
      "desktop": {
        "schemes": [
          "redddo",
          "reddtodo"
        ]
      }
    }
  }
}
